<Window x:Class="CalledAssistant.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CalledAssistant.ViewModels"
        xmlns:conv="clr-namespace:CalledAssistant.Converters"
        Title="Called Assistant"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="480"
        SizeToContent="Height"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- 颜色 -->
        <Color x:Key="BackgroundColor">#F0F4FD</Color>
        <Color x:Key="AccentColor">#4F7EFF</Color>
        <Color x:Key="DangerColor">#FF4F4F</Color>
        <Color x:Key="TextPrimary">#1A1D2E</Color>
        <Color x:Key="TextSecondary">#6B7280</Color>
        <Color x:Key="BorderColor">#D1D9F0</Color>

        <SolidColorBrush x:Key="BackgroundBrush"  Color="{StaticResource BackgroundColor}"/>
        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="DangerBrush"      Color="{StaticResource DangerColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"  Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="BorderBrush_"      Color="{StaticResource BorderColor}"/>

        <!-- 圆角按钮样式 -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush_}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D0DAFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主发送按钮 -->
        <Style x:Key="SendButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D6AE8"/>
                    <Setter Property="BorderBrush" Value="#3D6AE8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 录音按钮（激活时红色） -->
        <Style x:Key="MicButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecording}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 输入框样式 -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush_}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 音量条动画 -->
        <Style x:Key="VolumeBar" TargetType="Rectangle">
            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
            <Setter Property="RadiusX" Value="2"/>
            <Setter Property="RadiusY" Value="2"/>
        </Style>

        <!-- BoolToVisibility -->
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
        <!-- StringToVisibility -->
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
    </Window.Resources>

    <!-- 拖动支持 -->
    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            Margin="12"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.18" Color="#4F7EFF"/>
        </Border.Effect>

        <StackPanel Margin="20,16">

            <!-- 顶栏：标题 + 模式切换 + 关闭提示 -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Called" FontSize="15" FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>

                <!-- 模式切换按钮 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Style="{StaticResource IconButton}" Width="28" Height="28"
                            ToolTip="语音模式"
                            Command="{Binding SwitchToVoiceCommand}">
                        <TextBlock Text="🎤" FontSize="13" Margin="0,-1,0,0"/>
                    </Button>
                    <Button Style="{StaticResource IconButton}" Width="28" Height="28"
                            Margin="6,0,0,0" ToolTip="文字模式"
                            Command="{Binding SwitchToTextCommand}">
                        <TextBlock Text="⌨️" FontSize="13" Margin="0,-1,0,0"/>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="Esc 退出" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
            </Grid>

            <!-- 状态文本 -->
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,12" TextWrapping="Wrap"/>

            <!-- ========== 语音优先模式 ========== -->
            <Grid Visibility="{Binding IsVoiceMode, Converter={StaticResource BoolVis}}">
                <StackPanel>
                    <!-- 麦克风动画区域 -->
                    <Grid Height="72" Margin="0,0,0,12">
                        <!-- 音量可视化条（7根） -->
                        <ItemsControl HorizontalAlignment="Center" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- 麦克风大图标 + 停止/开始按钮 -->
                        <Button Style="{StaticResource MicButton}"
                                Width="64" Height="64"
                                HorizontalAlignment="Center"
                                Command="{Binding ToggleMicCommand}"
                                ToolTip="{Binding MicIconText}">
                            <TextBlock Text="{Binding MicIconText}" FontSize="28" Margin="0,-3,0,0"/>
                        </Button>
                    </Grid>

                    <!-- 识别到的文本 -->
                    <TextBlock Text="{Binding TranscribedText}"
                               Visibility="{Binding TranscribedText, Converter={StaticResource StrVis}}"
                               FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"
                               FontStyle="Italic" TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                </StackPanel>
            </Grid>

            <!-- ========== 文字优先模式 ========== -->
            <Grid Visibility="{Binding IsTextMode, Converter={StaticResource BoolVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TextInputBox"
                         Grid.Column="0"
                         Style="{StaticResource InputBox}"
                         Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="TextInput_KeyDown"
                         AcceptsReturn="False"
                         MaxLength="2000"
                         MinHeight="38"
                         VerticalScrollBarVisibility="Auto">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendTextCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- 语音输入按钮 -->
                <Button Grid.Column="1" Style="{StaticResource MicButton}"
                        Margin="8,0,0,0"
                        Command="{Binding ToggleMicCommand}"
                        ToolTip="语音输入">
                    <TextBlock Text="{Binding MicIconText}" FontSize="16" Margin="0,-1,0,0"/>
                </Button>

                <!-- 发送按钮 -->
                <Button Grid.Column="2" Style="{StaticResource SendButton}"
                        Margin="6,0,0,0"
                        Command="{Binding SendTextCommand}"
                        ToolTip="发送 (Enter)">
                    <TextBlock Text="➤" FontSize="14" Margin="2,-1,0,0"/>
                </Button>
            </Grid>

            <!-- ========== AI 回答区域 ========== -->
            <Border Visibility="{Binding ResponseText, Converter={StaticResource StrVis}}"
                    Background="White" CornerRadius="10"
                    BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                    Margin="0,12,0,0" Padding="12">
                <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto"
                              x:Name="ResponseScroll">
                    <TextBlock Text="{Binding ResponseText}"
                               FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap" LineHeight="22"/>
                </ScrollViewer>
            </Border>

            <!-- 处理中动画点 -->
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Left" Margin="0,10,0,0">
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="2,0"/>
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="2,0" Opacity="0.6"/>
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="2,0" Opacity="0.3"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
